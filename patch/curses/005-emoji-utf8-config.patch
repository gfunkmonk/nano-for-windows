      while( (i < n || n < 0) && str[i])
      {
 #ifdef PDC_WIDE
+#ifdef _WIN32
+        /* Inline 32-bit UTF-8 decoder for 3-byte and 4-byte sequences.
+         * This handles symbols (0xE0) and emoji (0xF0) that PDC_mbtowc can't convert 
+         * due to 16-bit wchar_t limitation. */
+        if ((unsigned char)str[i] >= 0xE0) {
+            int needed = ((unsigned char)str[i] >= 0xF0) ? 4 : 3;
+            
+            if (i + (needed - 1) < (n >= 0 ? n : (int)strlen(str))) {
+                uint32_t codepoint;
+                if (needed == 4) {
+                    codepoint = ((str[i] & 0x07) << 18) | ((str[i+1] & 0x3F) << 12) |
+                                ((str[i+2] & 0x3F) << 6) | (str[i+3] & 0x3F);
+                } else {
+                    codepoint = ((str[i] & 0x0F) << 12) | ((str[i+1] & 0x3F) << 6) |
+                                (str[i+2] & 0x3F);
+                }
+
+                if (waddch(win, (chtype)codepoint) == ERR)
+                    return ERR;
+                i += needed;
+                continue;
+            }
+        }
+#endif
          wchar_t wch;
          int retval = PDC_mbtowc(&wch, str + i, n >= 0 ? n - i : 6);
 
