+#ifdef PDC_WIDE
+#ifdef CHTYPE_64
+    /* Handle 32-bit Unicode code points for emoji support.
+     * Convert code points > 0xFFFF to surrogate pairs for WriteConsoleW. */
+    if (ch > 0xFFFF) {
+        /* Convert to UTF-16 surrogate pair */
+        WORD high_surrogate = 0xD800 + ((ch - 0x10000) >> 10);
+        WORD low_surrogate = 0xDC00 + ((ch - 0x10000) & 0x3FF);
+        
+        /* Write the surrogate pair */
+        WriteConsoleW(pdc_con_out, &high_surrogate, 1, &written, NULL);
+        WriteConsoleW(pdc_con_out, &low_surrogate, 1, &written, NULL);
+        return;
+    }
+#endif
+#endif
