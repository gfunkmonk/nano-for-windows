+/* Enable 64-bit chtype for proper emoji support on Windows.
+ * This allows storing full 32-bit Unicode code points without
+ * truncation that occurs with 16-bit wchar_t on Windows. */
+#ifndef CHTYPE_LONG
+#define CHTYPE_LONG 1
+#define CHTYPE_64 1
+#endif
