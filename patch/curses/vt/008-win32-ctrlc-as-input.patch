        rval = TRUE;
--- a/curses/vt/pdcscrn.c
+++ b/curses/vt/pdcscrn.c
@@ -34,6 +34,18 @@ bool PDC_resize_occurred = FALSE;
 
 #ifdef _WIN32
 
+int PDC_n_ctrl_c = 0;
+
+static BOOL WINAPI pdc_ctrl_handler( DWORD event_type)
+{
+    if( event_type == CTRL_C_EVENT && SP && SP->raw_inp)
+    {
+        PDC_n_ctrl_c++;
+        return TRUE;
+    }
+    return FALSE;
+}
+
 #ifndef ENABLE_VIRTUAL_TERMINAL_PROCESSING
 #define ENABLE_VIRTUAL_TERMINAL_PROCESSING 0x0004
 #endif
@@ -274,6 +286,7 @@ void PDC_scr_close( void)
    SP->_trap_mbe = 0;
    PDC_mouse_set( );          /* clear any mouse event captures */
 #ifdef _WIN32
+   SetConsoleCtrlHandler( pdc_ctrl_handler, FALSE);
    set_win10_for_vt_codes( FALSE);
 #else
    #if !defined( DOS)
@@ -346,6 +359,7 @@ int PDC_scr_open(void)
 #endif
 #ifdef _WIN32
     set_win10_for_vt_codes( TRUE);
+    SetConsoleCtrlHandler( pdc_ctrl_handler, TRUE);
 #endif
 
     PDC_LOG(("PDC_scr_open called\n"));
