 void PDC_transform_line(int lineno, int x, int len, const chtype *srcp)
 {
+    const chtype *full_line = srcp - x;
+    int start_col = x, end_col = x + len;
     static chtype prev_ch = 0;
     static bool force_reset_all_attribs = TRUE;
     char obuff[OBUFF_SIZE];
 
+    while (start_col > 0 && (full_line[start_col] & A_CHARTEXT) == MAX_UNICODE)
+        start_col--;
+
+    while (start_col > 0 && (PDC_has_emoji_or_joiner(full_line[start_col - 1]) ||
+           (full_line[start_col - 1] & A_CHARTEXT) == MAX_UNICODE))
+        start_col--;
+
+    while (end_col < SP->cols && (PDC_has_emoji_or_joiner(full_line[end_col]) ||
+           (full_line[end_col] & A_CHARTEXT) == MAX_UNICODE))
+        end_col++;
+
+    srcp = full_line + start_col;
+    x = start_col;
+    len = end_col - start_col;
+
+    while (len > 0 && (srcp[len - 1] & A_CHARTEXT) == MAX_UNICODE)
+        len--;
+
     if( !srcp)
     {
         prev_ch = 0;
