--- a/curses/wingui/pdcdisp.c	2026-05-20 00:00:00.000000000 -0400
+++ b/curses/wingui/pdcdisp.c	2026-05-20 00:00:00.000000000 -0400
@@ -820,11 +820,28 @@
-            int px_w = 0;
-            for (int t = start_col; t < start_col + run_cells; t++)
-            {
-                uint32_t cp = (uint32_t)(full_line[t] & A_CHARTEXT);
-                int w = PDC_wcwidth(cp);
-                px_w += (w == 2) ? 2 * PDC_cxChar : PDC_cxChar;
-            }
-
-            clip_rect.left = start_col * PDC_cxChar;
-            clip_rect.right = clip_rect.left + px_w;
+            int px_w = 0;
+            for (int t = start_col; t < start_col + run_cells; t++)
+            {
+                uint32_t cp = (uint32_t)(full_line[t] & A_CHARTEXT);
+                int w = PDC_wcwidth(cp);
+                px_w += (w == 2) ? 3 * PDC_cxChar : PDC_cxChar;
+            }
+
+            clip_rect.left = start_col * PDC_cxChar;
+            clip_rect.right = clip_rect.left + px_w;
+
+            /* Add a small padding so the Direct2D bind rect covers stray
+             * pixels from adjacent emoji/fullwidth glyphs and overlaps the
+             * cursor area to avoid visual artifacts. */
+            {
+                int pad = PDC_cxChar / 4;
+                if (pad < 2) pad = 2;
+                int maxw = SP->cols * PDC_cxChar;
+                if (clip_rect.left > pad)
+                    clip_rect.left -= pad;
+                else
+                    clip_rect.left = 0;
+                if (clip_rect.right + pad < maxw)
+                    clip_rect.right += pad;
+                else
+                    clip_rect.right = maxw;
+            }
