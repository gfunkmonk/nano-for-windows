+/* Convert a run of chtype cells to a proper UTF-16 string with surrogate
+ * pairs for SMP codepoints.  Expands COMBINED_CHAR_START values via
+ * PDC_expand_combined_characters so base+FE0F and similar sequences
+ * are passed to DirectWrite correctly. */
+static int PDC_srcp_to_utf16(const chtype *srcp, int ncells,
+                              wchar_t *out, int out_max)
+{
+    int olen = 0, i;
+#ifdef USING_COMBINING_CHARACTER_SCHEME
+    extern int PDC_expand_combined_characters( const cchar_t c, cchar_t *added);
+#endif
+    for (i = 0; i < ncells && olen < out_max - 4; i++)
+    {
+        uint32_t cp = (uint32_t)(srcp[i] & A_CHARTEXT);
+        if (cp == MAX_UNICODE || cp == 0) continue;
+#ifdef USING_COMBINING_CHARACTER_SCHEME
+        if (cp > MAX_UNICODE)
+        {
+            /* Expand the combined char chain into base + combining codepoints.
+             * PDC_expand_combined_characters(c, &added) returns root, sets added.
+             * We collect the chain then emit root first, then combining chars. */
+            cchar_t parts[16];
+            int nparts = 0;
+            cchar_t node = (cchar_t)cp;
+            while (node > (cchar_t)MAX_UNICODE && nparts < 15)
+            {
+                cchar_t added;
+                cchar_t root = PDC_expand_combined_characters(node, &added);
+                parts[nparts++] = added;
+                node = root;
+            }
+            /* node is now the base codepoint; emit it */
+            cp = (uint32_t)node;
+            if (cp >= 0x20 && olen < out_max - 2)
+            {
+                if (cp > 0xFFFF) {
+                    uint32_t s = cp - 0x10000;
+                    out[olen++] = (wchar_t)(0xD800 | (s >> 10));
+                    out[olen++] = (wchar_t)(0xDC00 | (s & 0x3FF));
+                } else {
+                    out[olen++] = (wchar_t)cp;
+                }
+            }
+            /* emit combining chars in reverse order (innermost collected first) */
+            for (int k = nparts - 1; k >= 0 && olen < out_max - 2; k--)
+            {
+                uint32_t ac = (uint32_t)parts[k];
+                if (!ac) continue;
+                if (ac > 0xFFFF) {
+                    uint32_t s = ac - 0x10000;
+                    out[olen++] = (wchar_t)(0xD800 | (s >> 10));
+                    out[olen++] = (wchar_t)(0xDC00 | (s & 0x3FF));
+                } else {
+                    out[olen++] = (wchar_t)ac;
+                }
+            }
+            continue;
+        }
+#endif
+        if (cp < 0x20) cp = 0x20;
+        if (cp > 0xFFFF) {
+            cp -= 0x10000;
+            out[olen++] = (wchar_t)(0xD800 | (cp >> 10));
+            out[olen++] = (wchar_t)(0xDC00 | (cp & 0x3FF));
+        } else {
+            out[olen++] = (wchar_t)cp;
+        }
+    }
+    out[olen] = 0;
+    return olen;
+}
