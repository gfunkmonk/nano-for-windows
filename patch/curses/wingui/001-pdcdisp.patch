+/* Uniscribe cache for text shaping performance */
+static SCRIPT_CACHE script_cache = NULL;
+
+/* Initialize or reset the Uniscribe script cache */
+static void PDC_init_script_cache( void)
+{
+    if( script_cache)
+    {
+        ScriptFreeCache( &script_cache);
+        script_cache = NULL;
+    }
+}
