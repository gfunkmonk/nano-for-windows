+/* Draw text using Uniscribe for proper complex script shaping */
+static BOOL PDC_draw_text_uniscribe( HDC hdc, const wchar_t *text, int len,
+                                      int x, int y, int width)
+{
+    HRESULT hr;
+    SCRIPT_ITEM *items = NULL;
+    SCRIPT_ANALYSIS *sa = NULL;
+    WORD *glyphs = NULL;
+    WORD *log_clusters = NULL;
+    SCRIPT_VISATTR *sva = NULL;
+    int *advances = NULL;
+    GOFFSET *offsets = NULL;
+    ABC *abc = NULL;
+    int max_items = 0, max_glyphs = 0;
+    int i, num_items, num_glyphs;
+    int total_width = 0;
+    
+    if( !text || len <= 0)
+        return FALSE;
+    
+    /* Allocate buffers for Uniscribe processing */
+    max_items = len + 1;
+    items = (SCRIPT_ITEM *)calloc( max_items, sizeof( SCRIPT_ITEM));
+    if( !items)
+        goto cleanup;
+    
+    /* Itemize the text into shaping runs */
+    hr = ScriptItemize( text, len, max_items, NULL, NULL, items, &num_items);
+    if( FAILED( hr) || num_items <= 0)
+        goto cleanup;
+    
+    /* Process each item */
+    for( i = 0; i < num_items; i++)
+    {
+        int item_len = items[i + 1].iCharPos - items[i].iCharPos;
+        SCRIPT_ANALYSIS *psa = &items[i].a;
+        
+        /* Allocate glyph buffers for this item */
+        max_glyphs = item_len * 2;  /* Worst case: 2 glyphs per char */
+        glyphs = (WORD *)calloc( max_glyphs, sizeof( WORD));
+        log_clusters = (WORD *)calloc( item_len, sizeof( WORD));
+        sva = (SCRIPT_VISATTR *)calloc( max_glyphs, sizeof( SCRIPT_VISATTR));
+        
+        if( !glyphs || !log_clusters || !sva)
+            goto cleanup;
+        
+        /* Shape the glyphs */
+        hr = ScriptShape( hdc, &script_cache, text + items[i].iCharPos,
+                          item_len, max_glyphs, psa, glyphs,
+                          log_clusters, sva, &num_glyphs);
+        
+        if( hr == USP_E_SCRIPT_NOT_IN_FONT)
+            goto cleanup;
+        
+        if( FAILED( hr))
+            goto cleanup;
+        
+        /* Get glyph positions */
+        advances = (int *)calloc( num_glyphs, sizeof( int));
+        offsets = (GOFFSET *)calloc( num_glyphs, sizeof( GOFFSET));
+        abc = (ABC *)calloc( 1, sizeof( ABC));
+        
+        if( !advances || !offsets || !abc)
+            goto cleanup;
+        
+        hr = ScriptPlace( hdc, &script_cache, glyphs, num_glyphs,
+                          sva, psa, advances, offsets, abc);
+        
+        if( FAILED( hr))
+            goto cleanup;
+        
+        /* Render the shaped text */
+        hr = ScriptTextOut( hdc, &script_cache, x + total_width, y,
+                           0, NULL, psa, NULL, 0, glyphs,
+                           num_glyphs, advances, NULL, offsets);
+        
+        if( FAILED( hr))
+            goto cleanup;
+        
+        total_width += abc->abcA + abc->abcB + abc->abcC;
+        
+        /* Free item-specific buffers */
+        free( glyphs); glyphs = NULL;
+        free( log_clusters); log_clusters = NULL;
+        free( sva); sva = NULL;
+        free( advances); advances = NULL;
+        free( offsets); offsets = NULL;
+        free( abc); abc = NULL;
+    }
+    
+    free( items);
+    return TRUE;
+    
+cleanup:
+    if( items) free( items);
+    if( glyphs) free( glyphs);
+    if( log_clusters) free( log_clusters);
+    if( sva) free( sva);
+    if( advances) free( advances);
+    if( offsets) free( offsets);
+    if( abc) free( abc);
+    return FALSE;
+}
+
+static bool PDC_has_emoji_or_joiner( const chtype ch)
+{
+    const uint32_t c = (uint32_t)(ch & A_CHARTEXT);
+
+    return( c == 0x200d                      /* ZWJ */
+         || (c >= 0xfe00 && c <= 0xfe0f)    /* variation selectors */
+         || (c >= 0x1f3fb && c <= 0x1f3ff)  /* skin tone modifiers */
+         || (c >= 0x1f1e6 && c <= 0x1f1ff)  /* regional indicators */
+         || (c >= 0x1f300 && c <= 0x1faff)  /* emoji blocks (roughly Unicode 15.x) */
+         || (c >= 0x2600 && c <= 0x27bf));  /* misc symbols/dingbats */
+}
