--- a/curses/wingui/pdcdisp.c
+++ b/curses/wingui/pdcdisp.c
@@ -220,7 +220,9 @@
     lf.lfPitchAndFamily = FF_MODERN;
     lf.lfWeight = ((font_idx & 1) ? FW_EXTRABOLD : FW_NORMAL);
     lf.lfItalic = ((font_idx & 2) ? TRUE : FALSE);
-    lf.lfCharSet = ANSI_CHARSET;
+    /* Allow full Unicode glyph selection (including emoji) instead of
+       restricting font matching to ANSI code pages. */
+    lf.lfCharSet = DEFAULT_CHARSET;
     lf.lfQuality = PROOF_QUALITY;
     lf.lfOutPrecision = OUT_RASTER_PRECIS;
     return( lf);
@@ -329,6 +331,20 @@
 
 #define BUFFSIZE 50
 
+static bool PDC_has_emoji_or_joiner( const chtype ch)
+{
+    const uint32_t c = (uint32_t)(ch & A_CHARTEXT);
+
+    return( c == 0x200d                      /* ZWJ */
+         || (c >= 0xfe00 && c <= 0xfe0f)    /* variation selectors */
+         || (c >= 0x1f3fb && c <= 0x1f3ff)  /* skin tone modifiers */
+         || (c >= 0x1f1e6 && c <= 0x1f1ff)  /* regional indicators */
+         || (c >= 0x1f300 && c <= 0x1faff)  /* emoji blocks (roughly Unicode 15.x) */
+         || (c >= 0x2600 && c <= 0x27bf));  /* misc symbols/dingbats */
+}
+
 static void PDC_transform_line_given_hdc( const HDC hdc, const int lineno,
                              int x, int len, const chtype *srcp)
 {
@@ -358,7 +374,14 @@
     assert( len <= SP->cols - x);
     assert( lineno < SP->lines && len > 0 && lineno >= 0);
 #ifdef PDC_WIDE
-    assert( (srcp[len - 1] & A_CHARTEXT) != MAX_UNICODE);
+    /* The trailing placeholder after a fullwidth character (MAX_UNICODE)
+     * can legitimately appear at the end of a transformed run.  Trim such
+     * placeholders instead of asserting, so emoji/fullwidth redraw paths do
+     * not abort in debug builds. */
+    while( len && (srcp[len - 1] & A_CHARTEXT) == MAX_UNICODE)
+        len--;
+    if( !len)
+        return;
 #endif
 
     while( len)
@@ -378,6 +401,7 @@
         RECT clip_rect;
         wchar_t buff[BUFFSIZE];
         int lpDx[BUFFSIZE + 1];
+        bool has_emoji_or_joiner = FALSE;
         int olen = 0;
 #ifdef USE_FALLBACK_FONT
         const bool in_font = character_is_in_font( *srcp);
@@ -391,6 +415,8 @@
         {
             chtype ch = srcp[i] & A_CHARTEXT;
 
+            has_emoji_or_joiner |= PDC_has_emoji_or_joiner( srcp[i]);
+
 #ifdef USING_COMBINING_CHARACTER_SCHEME
             if( ch > 0xffff && ch < MAX_UNICODE)  /* use Unicode surrogates to fit */
             {               /* >64K values into 16-bit wchar_t: */
@@ -495,7 +521,10 @@
         clip_rect.bottom = clip_rect.top + PDC_cyChar;
         ExtTextOutW( hdc, clip_rect.left, clip_rect.top,
                            ETO_CLIPPED | ETO_OPAQUE, &clip_rect,
-                           buff, olen, (olen > 1 ? lpDx : NULL));
+                           buff, olen,
+                           /* Let GDI shape emoji/ZWJ clusters naturally. */
+                           (olen > 1 && !has_emoji_or_joiner ?
+                                            lpDx : NULL));
 #ifdef WA_TOP
         if( *srcp & (WA_UNDERLINE | WA_RIGHT | WA_LEFT | WA_TOP | WA_STRIKEOUT))
 #else
@@ -557,7 +586,10 @@
 
         assert( len);
 #ifdef PDC_WIDE
-        assert( (srcp[len - 1] & A_CHARTEXT) != MAX_UNICODE);
+        while( len && (srcp[len - 1] & A_CHARTEXT) == MAX_UNICODE)
+            len--;
+        if( !len)
+            return;
 #endif
         PDC_transform_line_given_hdc( hdc, lineno, x, len, srcp);
         ReleaseDC( PDC_hWnd, hdc);
