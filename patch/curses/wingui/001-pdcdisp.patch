+/* Render an emoji run via Direct2D directly onto hdc.
+ * Uses D2D1_DRAW_TEXT_OPTIONS_ENABLE_COLOR_FONT to activate COLR color glyphs.
+ * srcp/ncells: raw chtype cells.  fg/bg: COLORREF.  cell_w/h: pixels. */
+static void PDC_d2d_render_emoji(
+        HDC hdc, int dst_x, int dst_y,
+        const chtype *srcp, int src_cells, int px_w,
+        COLORREF fg, COLORREF bg, int cell_w, int cell_h)
+{
+    wchar_t u16[BUFFSIZE * 2 + 1];
+    int nchars;
+    RECT bind_rect;
+    static HBRUSH cached_bg_brush = NULL;
+    static COLORREF cached_bg_color = 0;
+    D2D1_COLOR_F bg_color, fg_color;
+    D2D1_RECT_F  layout_rect;
+    extern int PDC_cxChar;
+    int pad = PDC_cxChar;
+    D2D1_POINT_2F origin = {0.0f, 0.0f};
+    IDWriteTextLayout *layout = NULL;
+    HRESULT hr;
+    D2D1_TAG t1, t2;
+
+    nchars = PDC_srcp_to_utf16(srcp, src_cells, u16, BUFFSIZE * 2);
+    if (nchars <= 0) return;
+
+    /* Bind the DC render target to the exact cell rectangle on the window DC. */
+    float desired_left = dst_x - pad;
+    float max_right = (float)(SP->cols * PDC_cxChar);
+    float desired_right = dst_x + px_w + cell_w + pad;
+    bind_rect.left = (desired_left > 0.0f) ? desired_left : 0.0f;
+    bind_rect.right = (desired_right < max_right) ? desired_right : max_right;
+    if (bind_rect.right <= bind_rect.left)
+    {
+        bind_rect.right = bind_rect.left + PDC_cxChar; /* safe fallback */
+    }
+    bind_rect.top    = dst_y;
+    bind_rect.bottom = dst_y + cell_h;
+    hr = ID2D1DCRenderTarget_BindDC(g_d2d_rt, hdc, &bind_rect);
+    if (FAILED(hr)) return;
+
+    /* Draw relative to the bound rectangle origin. */
+    origin.x = 0.0f;
+    origin.y = 0.0f;
+
+    if (bg != cached_bg_color || !cached_bg_brush) {
+        if (cached_bg_brush) {
+            DeleteObject(cached_bg_brush);
+        }
+        cached_bg_brush = CreateSolidBrush(bg);
+        cached_bg_color = bg;
+    }
+
+    /* Build text layout. */
+    hr = IDWriteFactory_CreateTextLayout(
+            g_dw_factory, u16, (UINT32)nchars,
+            g_dw_fmt, (FLOAT)px_w, (FLOAT)cell_h, &layout);
+    if (FAILED(hr) || !layout) return;
+
+    /* Keep the emoji run on one line; wrapped text would be clipped by the
+     * single-cell-high DC render target and look like truncated glyphs. */
+    IDWriteTextLayout_SetWordWrapping(layout, DWRITE_WORD_WRAPPING_NO_WRAP);
+
+    /* Convert COLORREF to D2D1_COLOR_F (0..1 range, BGRA→RGBA). */
+    bg_color.r = (float)GetRValue(bg) / 255.0f;
+    bg_color.g = (float)GetGValue(bg) / 255.0f;
+    bg_color.b = (float)GetBValue(bg) / 255.0f;
+    bg_color.a = 1.0f;
+    fg_color.r = (float)GetRValue(fg) / 255.0f;
+    fg_color.g = (float)GetGValue(fg) / 255.0f;
+    fg_color.b = (float)GetBValue(fg) / 255.0f;
+    fg_color.a = 1.0f;
+
+    layout_rect.left = layout_rect.top = 0.0f;
+    layout_rect.right  = (FLOAT)px_w;
+    layout_rect.bottom = (FLOAT)cell_h;
+
+    ID2D1DCRenderTarget_BeginDraw(g_d2d_rt);
+
+    /* Fill only this run's background; don't clear the entire bound DC area. */
+    ID2D1SolidColorBrush_SetColor(g_d2d_brush, &bg_color);
+    ID2D1DCRenderTarget_FillRectangle(g_d2d_rt, &layout_rect,
+            (ID2D1Brush *)g_d2d_brush);
+
+    /* Set brush color to foreground (used for monochrome fallback glyphs). */
+    ID2D1SolidColorBrush_SetColor(g_d2d_brush, &fg_color);
+
+    /* DrawTextLayout with ENABLE_COLOR_FONT activates COLR color emoji. */
+    ID2D1DCRenderTarget_DrawTextLayout(g_d2d_rt, origin, layout,
+            (ID2D1Brush *)g_d2d_brush,
+            D2D1_DRAW_TEXT_OPTIONS_ENABLE_COLOR_FONT);
+
+    /* Flush ensures complete rendering to avoid partial-frame artifacts. */
+    ID2D1DCRenderTarget_Flush(g_d2d_rt, &t1, &t2);
+
+    ID2D1DCRenderTarget_EndDraw(g_d2d_rt, &t1, &t2);
+    IDWriteTextLayout_Release(layout);
+}
+
+static bool PDC_has_emoji_or_joiner(const chtype ch)
+{
+    const uint32_t c = (uint32_t)(ch & A_CHARTEXT);
+
+    if ((c >= '0' && c <= '9') || c == '#' || c == '*') return true;
+    return( c == 0x200d                     /* ZWJ */
+         || c == 0x200c                     /* ZWNJ */
+         || c == 0x20e3                     /* combining enclosing keycap */
+         || (c >= 0xD800 && c <= 0xd87f)    /* high surrogates */
+         || (c >= 0xDc00 && c <= 0xdfff)    /* low surrogates */
+         || (c >= 0x0000 && c <= 0xffff)    /* bmp symbol */
+         || (c >= 0xfe00 && c <= 0xfe0f)    /* variation selectors */
+         || (c >= 0xe0020 && c <= 0xe007f)  /* Unicode Tags (flags) */
+         || (c >= 0x1f3fb && c <= 0x1f3ff)  /* skin tone modifiers */
+         || (c >= 0x1f1e6 && c <= 0x1f1ff)  /* regional indicators */
+         || (c >= 0x10000 && c <= 0x1faff)  /* emoji blocks */
+         || (c >= 0x2600 && c <= 0x27bf)    /* misc symbols */
+         || c == MAX_UNICODE                /* Wide character continuation */
+         || c > MAX_UNICODE);               /* combined char (base+VS/ZWJ) */
+}
