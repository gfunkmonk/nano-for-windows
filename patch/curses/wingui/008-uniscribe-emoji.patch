+static void PDC_render_with_uniscribe( const HDC hdc, const wchar_t *text, int len,
+                                       int x, int y, int width, const RECT *clip_rect)
+{
+    SCRIPT_CONTROL sc = {0};
+    SCRIPT_STATE ss = {0};
+    SCRIPT_ITEM *items = NULL;
+    int max_items = 16;
+    int n_items = 0;
+    HRESULT hr;
+    int i;
+    
+    items = (SCRIPT_ITEM *)calloc( max_items, sizeof( SCRIPT_ITEM));
+    if( !items)
+        goto cleanup;
+    
+    hr = ScriptItemize( text, len, max_items, &sc, &ss, items, &n_items);
+    if( hr == E_OUTOFMEMORY)
+    {
+        free( items);
+        max_items = len + 1;
+        items = (SCRIPT_ITEM *)calloc( max_items, sizeof( SCRIPT_ITEM));
+        if( !items)
+            goto cleanup;
+        hr = ScriptItemize( text, len, max_items, &sc, &ss, items, &n_items);
+    }
+    
+    if( FAILED( hr))
+        goto cleanup;
+    
+    for( i = 0; i < n_items; i++)
+    {
+        int item_len = items[i + 1].iCharPos - items[i].iCharPos;
+        SCRIPT_ANALYSIS *psa = &items[i].a;
+        int cGlyphs = 0;
+        WORD *pwGlyphs = NULL;
+        SCRIPT_VISATTR *psva = NULL;
+        int *piAdvance = NULL;
+        GOFFSET *pGoffset = NULL;
+        ABC abc;
+        
+        hr = ScriptShape( hdc, &psa->eScript, text + items[i].iCharPos, item_len,
+                          max_items, psa, NULL, pwGlyphs, psva, &cGlyphs);
+        if( hr == E_OUTOFMEMORY)
+        {
+            pwGlyphs = (WORD *)calloc( item_len * 2, sizeof( WORD));
+            psva = (SCRIPT_VISATTR *)calloc( item_len * 2, sizeof( SCRIPT_VISATTR));
+            if( !pwGlyphs || !psva)
+                goto item_cleanup;
+            
+            hr = ScriptShape( hdc, &psa->eScript, text + items[i].iCharPos, item_len,
+                              item_len * 2, psa, NULL, pwGlyphs, psva, &cGlyphs);
+        }
+        
+        if( FAILED( hr))
+            goto item_cleanup;
+        
+        piAdvance = (int *)calloc( cGlyphs, sizeof( int));
+        pGoffset = (GOFFSET *)calloc( cGlyphs, sizeof( GOFFSET));
+        if( !piAdvance || !pGoffset)
+            goto item_cleanup;
+        
+        hr = ScriptPlace( hdc, psa, pwGlyphs, cGlyphs, psva,
+                          &psa->f, piAdvance, pGoffset, &abc);
+        if( FAILED( hr))
+            goto item_cleanup;
+        
+        ScriptTextOut( hdc, psa, x, y, 0, clip_rect,
+                      text + items[i].iCharPos, item_len,
+                      pwGlyphs, cGlyphs, piAdvance, pGoffset, &abc);
+        
+        x += abc.abcA + abc.abcB + abc.abcC;
+        
+item_cleanup:
+        if( pwGlyphs) free( pwGlyphs);
+        if( psva) free( psva);
+        if( piAdvance) free( piAdvance);
+        if( pGoffset) free( pGoffset);
+    }
+    
+cleanup:
+    if( items) free( items);
+}
