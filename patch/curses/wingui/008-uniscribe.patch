+static bool PDC_render_with_uniscribe( const HDC hdc, const wchar_t *text, int len,
+                                       int x, int y, int width, const RECT *clip_rect)
+{
+    SCRIPT_CONTROL sc = {0};
+    SCRIPT_STATE ss = {0};
+    SCRIPT_ITEM *items = NULL;
+    int max_items = 16;
+    int n_items = 0;
+    HRESULT hr;
+    int i;
+    bool success = FALSE;
+    char msg[256];
+
+    items = (SCRIPT_ITEM *)calloc( max_items, sizeof( SCRIPT_ITEM));
+    if( !items)
+    {
+        MessageBoxA( NULL, "Failed to allocate items", "Uniscribe Error", MB_OK);
+        goto cleanup;
+    }
+
+    hr = ScriptItemize( text, len, max_items, &sc, &ss, items, &n_items);
+    if( hr == E_OUTOFMEMORY)
+    {
+        free( items);
+        max_items = len + 1;
+        items = (SCRIPT_ITEM *)calloc( max_items, sizeof( SCRIPT_ITEM));
+        if( !items)
+        {
+            MessageBoxA( NULL, "Failed to allocate items (retry)", "Uniscribe Error", MB_OK);
+            goto cleanup;
+        }
+        hr = ScriptItemize( text, len, max_items, &sc, &ss, items, &n_items);
+    }
+
+    if( FAILED( hr))
+    {
+        sprintf( msg, "ScriptItemize failed: 0x%08lX", (unsigned long)hr);
+        MessageBoxA( NULL, msg, "Uniscribe Error", MB_OK);
+        goto cleanup;
+    }
+
+    for( i = 0; i < n_items; i++)
+    {
+        int item_len = items[i + 1].iCharPos - items[i].iCharPos;
+        SCRIPT_ANALYSIS *psa = &items[i].a;
+        int cGlyphs = 0;
+        WORD *pwGlyphs = NULL;
+        WORD *pwLogClust = NULL;
+        SCRIPT_VISATTR *psva = NULL;
+        int *piAdvance = NULL;
+        GOFFSET *pGoffset = NULL;
+        ABC abc;
+        SCRIPT_CACHE psc = NULL;
+        SCRIPT_FONTPROPERTIES sfp;
+        WORD default_glyph = 0;
+        bool has_default_glyph = FALSE;
+        int glyph_idx;
+
+        pwGlyphs = (WORD *)calloc( item_len * 2, sizeof( WORD));
+        pwLogClust = (WORD *)calloc( item_len, sizeof( WORD));
+        psva = (SCRIPT_VISATTR *)calloc( item_len * 2, sizeof( SCRIPT_VISATTR));
+        if( !pwGlyphs || !pwLogClust || !psva)
+        {
+            MessageBoxA( NULL, "Failed to allocate glyphs/visattr", "Uniscribe Error", MB_OK);
+            goto item_cleanup;
+        }
+
+        hr = ScriptShape( hdc, &psc, text + items[i].iCharPos, item_len,
+                          item_len * 2, psa, pwGlyphs, pwLogClust, psva, &cGlyphs);
+        if( FAILED( hr))
+        {
+            sprintf( msg, "ScriptShape failed: 0x%08lX", (unsigned long)hr);
+            MessageBoxA( NULL, msg, "Uniscribe Error", MB_OK);
+            goto item_cleanup;
+        }
+
+        memset( &sfp, 0, sizeof( sfp));
+        sfp.cBytes = sizeof( sfp);
+        hr = ScriptGetFontProperties( hdc, &psc, &sfp);
+        if( SUCCEEDED( hr))
+        {
+            default_glyph = sfp.wgDefault;
+            has_default_glyph = TRUE;
+        }
+
+        for( glyph_idx = 0; has_default_glyph && glyph_idx < cGlyphs; glyph_idx++)
+            if( pwGlyphs[glyph_idx] == default_glyph)
+            {
+                MessageBoxA( NULL, "Uniscribe produced fallback glyph - using GDI fallback",
+                             "Rendering", MB_OK);
+                goto item_cleanup;
+            }
+
+        piAdvance = (int *)calloc( cGlyphs, sizeof( int));
+        pGoffset = (GOFFSET *)calloc( cGlyphs, sizeof( GOFFSET));
+        if( !piAdvance || !pGoffset)
+        {
+            MessageBoxA( NULL, "Failed to allocate advance/goffset", "Uniscribe Error", MB_OK);
+            goto item_cleanup;
+        }
+
+        hr = ScriptPlace( hdc, &psc, pwGlyphs, cGlyphs, psva, psa,
+                          piAdvance, pGoffset, &abc);
+        if( FAILED( hr))
+        {
+            sprintf( msg, "ScriptPlace failed: 0x%08lX", (unsigned long)hr);
+            MessageBoxA( NULL, msg, "Uniscribe Error", MB_OK);
+            goto item_cleanup;
+        }
+
+        hr = ScriptTextOut( hdc, &psc, x, y, 0, clip_rect, psa,
+                      NULL, 0, pwGlyphs, cGlyphs, piAdvance, NULL, pGoffset);
+        if( FAILED( hr))
+        {
+            sprintf( msg, "ScriptTextOut failed: 0x%08lX", (unsigned long)hr);
+            MessageBoxA( NULL, msg, "Uniscribe Error", MB_OK);
+            goto item_cleanup;
+        }
+
+        x += abc.abcA + abc.abcB + abc.abcC;
+        success = TRUE;
+
+item_cleanup:
+        if( pwGlyphs) free( pwGlyphs);
+        if( pwLogClust) free( pwLogClust);
+        if( psva) free( psva);
+        if( piAdvance) free( piAdvance);
+        if( pGoffset) free( pGoffset);
+        if( psc) ScriptFreeCache( &psc);
+        if( !success)
+            goto cleanup;
+    }
+
+cleanup:
+    if( items) free( items);
+    return success;
+}
