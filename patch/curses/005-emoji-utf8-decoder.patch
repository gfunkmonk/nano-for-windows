+#ifdef PDC_WIDE
+/* Inline 32-bit UTF-8 decoder to replace PDC_mbtowc for proper emoji support.
+ * This function decodes UTF-8 sequences directly to 32-bit Unicode code points,
+ * avoiding the 16-bit wchar_t limitation on Windows. */
+static int pdc_utf8_to_char(const char *src, chtype *dest)
+{
+    const unsigned char *s = (const unsigned char *)src;
+    chtype result;
+    int len = 1;
+    uint32_t codepoint = 0;
+    
+    if (s[0] < 0x80) {
+        /* 1-byte sequence: 0xxxxxxx */
+        codepoint = s[0];
+        len = 1;
+    } else if ((s[0] & 0xE0) == 0xC0) {
+        /* 2-byte sequence: 110xxxxx 10xxxxxx */
+        if (s[1] && (s[1] & 0xC0) == 0x80) {
+            codepoint = ((s[0] & 0x1F) << 6) | (s[1] & 0x3F);
+            len = 2;
+        } else {
+            return -1; /* Invalid sequence */
+        }
+    } else if ((s[0] & 0xF0) == 0xE0) {
+        /* 3-byte sequence: 1110xxxx 10xxxxxx 10xxxxxx */
+        if (s[1] && s[2] && 
+            (s[1] & 0xC0) == 0x80 && (s[2] & 0xC0) == 0x80) {
+            codepoint = ((s[0] & 0x0F) << 12) | 
+                       ((s[1] & 0x3F) << 6) | 
+                       (s[2] & 0x3F);
+            len = 3;
+        } else {
+            return -1; /* Invalid sequence */
+        }
+    } else if ((s[0] & 0xF8) == 0xF0) {
+        /* 4-byte sequence: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx */
+        if (s[1] && s[2] && s[3] &&
+            (s[1] & 0xC0) == 0x80 && 
+            (s[2] & 0xC0) == 0x80 && 
+            (s[3] & 0xC0) == 0x80) {
+            codepoint = ((s[0] & 0x07) << 18) |
+                       ((s[1] & 0x3F) << 12) |
+                       ((s[2] & 0x3F) << 6) |
+                       (s[3] & 0x3F);
+            len = 4;
+        } else {
+            return -1; /* Invalid sequence */
+        }
+    } else {
+        return -1; /* Invalid UTF-8 start byte */
+    }
+    
+    /* Validate Unicode code point range */
+    if (codepoint > 0x10FFFF || 
+        (codepoint >= 0xD800 && codepoint <= 0xDFFF)) /* Surrogate range */
+        return -1;
+    
+    /* Store the code point in the chtype. With CHTYPE_64, we can store
+     * the full 32-bit code point directly. */
+#ifdef CHTYPE_64
+    result = codepoint | (A_CHARTEXT & SP->termattrs);
+#else
+    /* For non-64-bit chtype, we have to handle surrogate pairs */
+    if (codepoint > 0xFFFF) {
+        /* Convert to surrogate pair - this will be handled by display code */
+        uint16_t high = 0xD800 + ((codepoint - 0x10000) >> 10);
+        uint16_t low = 0xDC00 + ((codepoint - 0x10000) & 0x3FF);
+        /* For now, store the high surrogate. The display code will handle the pair. */
+        result = high | (A_CHARTEXT & SP->termattrs);
+    } else {
+        result = (chtype)codepoint | (A_CHARTEXT & SP->termattrs);
+    }
+#endif
+    
+    *dest = result;
+    return len;
+}
+#endif
