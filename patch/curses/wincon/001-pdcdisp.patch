+#ifdef USING_COMBINING_CHARACTER_SCHEME
+        /* Skip the placeholder cell that follows a fullwidth character.
+         * Writing the noncharacter U+10FFFF here would (a) display garbage
+         * in some terminals and (b) break ZWJ joining of adjacent emoji,
+         * because the cluster has to reach the terminal as an unbroken
+         * sequence of code points. */
+        if( ch == DUMMY_CHAR_NEXT_TO_FULLWIDTH)
+            continue;
+        /* Expand a combined-character cell (base + variation selector,
+         * base + ZWJ, multi-mark cluster, ...) into its component code
+         * points so the terminal can compose them.  added[] is filled
+         * outermost-first, so we emit root, then added[n_added] (oldest
+         * combiner), ..., added[0] (newest combiner). */
+        if( ch > MAX_UNICODE)
+        {
+            cchar_t added[10];
+            chtype  root = ch;
+            int     n_added = 0;
+            int     k, depth = 0;
+
+            while( depth++ < 31 &&
+                   (root = PDC_expand_combined_characters( root,
+                                   &added[n_added])) > MAX_UNICODE)
+                n_added++;
+
+            if( root <= MAX_UNICODE)
+            {
+                if( IS_SUPPLEMENTAL_MULTILINGUAL_PLANE( root))
+                {
+                    buffer[n_out++] = (WCHAR)((root - 0x10000) >> 10 | 0xD800);
+                    buffer[n_out++] = (WCHAR)((root & 0x3FF) | 0xDC00);
+                }
+                else
+                    buffer[n_out++] = (WCHAR)root;
+            }
+            for( k = n_added - 1; k >= 0; k--)
+            {
+                const chtype c = (chtype)added[k];
+
+                if( c == DUMMY_CHAR_NEXT_TO_FULLWIDTH)
+                    continue;
+                if( IS_SUPPLEMENTAL_MULTILINGUAL_PLANE( c))
+                {
+                    buffer[n_out++] = (WCHAR)((c - 0x10000) >> 10 | 0xD800);
+                    buffer[n_out++] = (WCHAR)((c & 0x3FF) | 0xDC00);
+                }
+                else
+                    buffer[n_out++] = (WCHAR)c;
+            }
+            continue;
+        }
+#endif
