+static bool PDC_has_emoji_or_joiner(const chtype ch)
+{
+    const uint32_t c = (uint32_t)(ch & A_CHARTEXT);
+
+    if ((c >= '0' && c <= '9') || c == '#' || c == '*') return true;
+    return( c == 0x200d                     /* ZWJ */
+         || c == 0x200c                     /* ZWNJ */
+         || c == 0x20e3                     /* combining enclosing keycap */
+         || (c >= 0xfe00 && c <= 0xfe0f)    /* variation selectors */
+         || (c >= 0x2600 && c <= 0x270f)    /* Various Emoji */
+         || (c >= 0x1100 && c <= 0x11ff)    /* Hangul Jamo */
+         || (c >= 0x16a0 && c <= 0x16ff)    /* Runic */
+         || (c >= 0x2e80 && c <= 0x9fff)    /* CJK, Hangul compat, Katakana, CJK unified */
+         || (c >= 0xac00 && c <= 0xd7af)    /* Hangul syllables */
+         || (c >= 0xf900 && c <= 0xfaff)    /* CJK compatibility ideographs */
+         || (c >= 0xff00 && c <= 0xffef)    /* fullwidth/halfwidth forms */
+         || (c >= 0xe0020 && c <= 0xe007f)  /* Unicode Tags (flags) */
+         || (c >= 0x1f1e6 && c <= 0x1f1ff)  /* regional indicators */
+         || (c >= 0x1f3fb && c <= 0x1f3ff)  /* skin tone modifiers */
+         || (c >= 0x10000 && c <= 0x1faff)  /* emoji blocks (SMP) */
+         || c == MAX_UNICODE                /* wide-char continuation dummy */
+         || c > MAX_UNICODE);               /* combined char (base+VS/ZWJ) */
+}
