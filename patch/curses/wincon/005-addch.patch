--- a/curses/pdcurses/addch.c
+++ b/curses/pdcurses/addch.c
@@ -535,6 +535,22 @@ int waddch( WINDOW *win, const chtype ch)
 
     if( x || y)
     {
+        /* Keep emoji joiners/modifiers in the combining path. */
+        const bool is_zwj = (text == 0x200D);
+        const bool is_variation_selector = (text >= 0xFE00 && text <= 0xFE0F);
+        const bool is_skin_tone_modifier = (text >= 0x1F3FB && text <= 0x1F3FF);
+        const bool is_keycap_joiner = (text == 0x20E3);
+
+        if( is_zwj || is_skin_tone_modifier || is_keycap_joiner)
+            text_width = 1;
+
+        if (is_variation_selector)
+        {
+            if( x > 0)
+                win->_y[y][x - 1] = COMBINED_CHAR_START
+                                    + PDC_find_combined_char_idx( win->_y[y][x - 1], text);
+            return OK;
+        }
         const bool is_combining = (text && !text_width);
         const bool is_low_surrogate = PDC_IS_LOW_SURROGATE( text);
 
@@ -550,6 +566,11 @@ int waddch( WINDOW *win, const chtype ch)
                 x = win->_maxx - 1;
             }
             prev_char = win->_y[y][x] & A_CHARTEXT;
+            if( prev_char == DUMMY_CHAR_NEXT_TO_FULLWIDTH && x)
+            {
+                x--;
+                prev_char = win->_y[y][x] & A_CHARTEXT;
+            }
             if( is_combining)
                 text = COMBINED_CHAR_START
                          + PDC_find_combined_char_idx( prev_char, text);

