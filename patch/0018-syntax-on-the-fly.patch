From 962d04f9c7fddaec6db1e50692869c9a80482bf2 Mon Sep 17 00:00:00 2001
From: davidhcefx <davidhu0903ex3@gmail.com>
Date: Fri, 6 Feb 2026 17:04:55 +0800
Subject: [PATCH] Feature: change syntax highlighting on-the-fly

---
 doc/nanorc.5     |  3 +++
 src/global.c     |  4 ++++
 src/prototypes.h |  1 +
 src/rcfile.c     |  2 ++
 src/text.c       | 38 ++++++++++++++++++++++++++++++++++++++
 5 files changed, 48 insertions(+)

diff --git a/doc/nanorc.5 b/doc/nanorc.5
index ad712e30..685897f9 100644
--- a/doc/nanorc.5
+++ b/doc/nanorc.5
@@ -693,6 +693,9 @@ the line, column, and character positions.
 Counts and reports on the status bar the number of lines, words,
 and characters in the current buffer (or in the marked region).
 .TP
+.B setsyntax
+Prompts for new syntax highlighting to be applied.
+.TP
 .B execute
 Prompts for a program to execute.  The program's output will be inserted
 into the current buffer (or into a new buffer when \fBM\-F\fR is toggled).
diff --git a/src/global.c b/src/global.c
index 0a32f139..54f98f3d 100644
--- a/src/global.c
+++ b/src/global.c
@@ -623,6 +623,7 @@ void shortcut_init(void)
        const char *wordcount_gist =
                N_("Count the number of lines, words, and characters");
        const char *suspend_gist = N_("Suspend the editor (return to the shell)");
+       const char *setsyntax_gist = N_("Set new syntax highlighting");
 #endif
        const char *refresh_gist = N_("Refresh (redraw) the current screen");
 #ifdef ENABLE_WORDCOMPLETION
@@ -978,6 +979,8 @@ void shortcut_init(void)
 #ifndef NANO_TINY
        add_to_funcs(count_lines_words_and_characters, MMAIN,
                N_("Word Count"), WITHORSANS(wordcount_gist), TOGETHER, VIEW);
+       add_to_funcs(do_set_syntax, MMAIN,
+               N_("Set Syntax"), WITHORSANS(setsyntax_gist), TOGETHER, NOVIEW);
 #endif

        add_to_funcs(do_verbatim_input, MMAIN,
@@ -1355,6 +1358,7 @@ void shortcut_init(void)
        add_to_sclist(MEXECUTE, "^Z", 0, do_suspend, 0);
        add_to_sclist(MMAIN, "^Z", 0, suggest_ctrlT_ctrlZ, 0);
        add_to_sclist(MMAIN, "M-D", 0, count_lines_words_and_characters, 0);
+       add_to_sclist(MMAIN, "M-5", 0, do_set_syntax, 0);
 #else
        add_to_sclist(MMAIN, "M-H", 0, do_help, 0);
 #endif
diff --git a/src/prototypes.h b/src/prototypes.h
index cf79680e..b0642503 100644
--- a/src/prototypes.h
+++ b/src/prototypes.h
@@ -519,6 +519,7 @@ void do_formatter(void);
 #endif
 #ifndef NANO_TINY
 void count_lines_words_and_characters(void);
+void do_set_syntax(void);
 #endif
 void do_verbatim_input(void);
 void complete_a_word(void);
diff --git a/src/rcfile.c b/src/rcfile.c
index 049a2886..abb6e8f0 100644
--- a/src/rcfile.c
+++ b/src/rcfile.c
@@ -321,6 +321,8 @@ keystruct *strtosc(const char *input)
                s->func = do_find_bracket;
        else if (!strcmp(input, "wordcount"))
                s->func = count_lines_words_and_characters;
+       else if (!strcmp(input, "setsyntax"))
+               s->func = do_set_syntax;
        else if (!strcmp(input, "recordmacro"))
                s->func = record_macro;
        else if (!strcmp(input, "runmacro"))
diff --git a/src/text.c b/src/text.c
index 85d1bd40..6f0ab8a2 100644
--- a/src/text.c
+++ b/src/text.c
@@ -2969,6 +2969,44 @@ void count_lines_words_and_characters(void)
                                                words, P_("word", "words", words),
                                                chars, P_("character", "characters", chars));
 }
+
+/* Prompt user for changing to the new syntax highlighting. We use the spell menu because
+ * it has no functions. */
+void do_set_syntax(void)
+{
+       int response;
+       const char *oldname, *newname;
+       linestruct *line;
+
+       if (openfile->syntax) {
+               response = do_prompt(MSPELL, "", NULL, edit_refresh, "Syntax Name [%s]", openfile->syntax->name);
+       } else {
+               response = do_prompt(MSPELL, "", NULL, edit_refresh, "Syntax Name");
+       }
+       if (response < 0) {
+               statusbar(_("Cancelled"));
+               return;
+       }
+       if (*answer == '\0')
+       return;
+
+       syntaxstr = mallocstrcpy(syntaxstr, answer);
+       oldname = openfile->syntax ? openfile->syntax->name : "";
+       find_and_prime_applicable_syntax();
+       newname = openfile->syntax ? openfile->syntax->name : "";
+
+       /* If the syntax changed, discard and recompute the multidata. */
+       if (strcmp(oldname, newname) != 0) {
+               for (line = openfile->filetop; line != NULL; line = line->next) {
+                       free(line->multidata);
+                       line->multidata = NULL;
+               }
+
+               precalc_multicolorinfo();
+               have_palette = FALSE;
+               refresh_needed = TRUE;
+       }
+}
 #endif /* !NANO_TINY */

 /* Get verbatim input. */
--
2.41.0
