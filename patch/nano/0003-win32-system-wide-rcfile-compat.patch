From cffbdab132eebe0df8b1a39ddb6677ca40d0a8fc Mon Sep 17 00:00:00 2001
From: Chawye Hsu <su+git@chawyehsu.com>
Date: Sat, 18 Apr 2026 04:08:13 +0800
Subject: [PATCH 03/17] win32: system-wide rcfile compat

Signed-off-by: Chawye Hsu <su+git@chawyehsu.com>
---
 src/rcfile.c | 13 ++++++++++++-
 1 file changed, 12 insertions(+), 1 deletion(-)

diff --git a/src/rcfile.c b/src/rcfile.c
index 696599b..2531959 100644
--- a/src/rcfile.c
+++ b/src/rcfile.c
@@ -1743,8 +1743,19 @@ void do_rcfiles(void)
 			parse_one_nanorc();
 	} else {
 		const char *xdgconfdir;
+		const char *sysconfdir = SYSCONFDIR;
+
+#ifdef _WIN32
+		/* For the system-wide nanorc file, use SYSCONFDIR if defined
+		 * at compile time; otherwise, use %ALLUSERSPROFILE%\nanorc. */
+		if (sysconfdir == NULL || sysconfdir[0] == '\0') {
+			sysconfdir = getenv("ALLUSERSPROFILE");
+			if (sysconfdir == NULL || sysconfdir[0] == '\0')
+				sysconfdir = "C:/ProgramData";
+		}
+#endif
 
-		if (have_nanorc(SYSCONFDIR, "/nanorc"))
+		if (have_nanorc(sysconfdir, "/nanorc"))
 			parse_one_nanorc();
 
 		get_homedir();
-- 
