+#ifdef _WIN32
+#include <windows.h>
+
+/* Manually fetch UTF-16 from clipboard and convert to UTF-8 to prevent emoji garbling. */
+void win32_paste_utf8(void)
+{
+    if (!IsClipboardFormatAvailable(CF_UNICODETEXT))
+        return;
+
+    if (OpenClipboard(NULL)) {
+        HANDLE hData = GetClipboardData(CF_UNICODETEXT);
+        if (hData) {
+            wchar_t *pText = (wchar_t *)GlobalLock(hData);
+            if (pText) {
+                int size = WideCharToMultiByte(CP_UTF8, 0, pText, -1, NULL, 0, NULL, NULL);
+                char *utf8_str = nmalloc(size);
+
+                WideCharToMultiByte(CP_UTF8, 0, pText, -1, utf8_str, size, NULL, NULL);
+
+                /* Inject the converted string into the current buffer. */
+                do_verbatim_input(utf8_str);
+
+                free(utf8_str);
+                GlobalUnlock(hData);
+            }
+        }
+        CloseClipboard();
+    }
+    currmenu = MMAIN;
+    refresh_needed = TRUE;
+}
+#endif
+
