 #include "prototypes.h"
 
+#if defined(_WIN32) && defined(SAVE_GUI)
+/* -----------------------------------------------------------------------
+ * Native Windows file-picker dialogs for the wingui (SAVE_GUI) build.
+ *
+ * GetOpenFileName / GetSaveFileName are provided by comdlg32, which is
+ * already linked for the wingui target.  PDC_hWnd is the top-level window
+ * created by PDCurses/wingui and is used as the dialog owner so it
+ * behaves as a proper modal child of the editor window.
+ *
+ * Both helpers write their result into the global `answer` buffer and
+ * return TRUE.  On cancel they return FALSE and the caller falls through
+ * to the normal TUI prompt.
+ * ----------------------------------------------------------------------- */
+#include <commdlg.h>
+
+extern HWND PDC_hWnd;
+
+/* Pop a Save-As dialog.  `initial` is the filename to pre-populate.
+ * On success writes the chosen path into `answer` and returns TRUE. */
+static bool win32_save_dialog(const char *initial)
+{
+   char buf[MAX_PATH];
+   OPENFILENAMEA ofn;
+
+   strncpy(buf, initial ? initial : "", MAX_PATH - 1);
+   buf[MAX_PATH - 1] = '\0';
+
+   memset(&ofn, 0, sizeof(ofn));
+   ofn.lStructSize = sizeof(ofn);
+   ofn.hwndOwner   = PDC_hWnd;
+   ofn.lpstrFile   = buf;
+   ofn.nMaxFile    = MAX_PATH;
+   ofn.lpstrTitle  = "Save File As";
+   ofn.Flags       = OFN_OVERWRITEPROMPT | OFN_NOCHANGEDIR | OFN_PATHMUSTEXIST;
+
+   if (!GetSaveFileNameA(&ofn))
+       return FALSE;
+
+   normalize_slashes(buf);
+   answer = mallocstrcpy(answer, buf);
+   return TRUE;
+}
+
+/* Pop an Open dialog.  On success writes the chosen path into `answer`
+ * and returns TRUE. */
+static bool win32_open_dialog(void)
+{
+   char buf[MAX_PATH] = "";
+   OPENFILENAMEA ofn;
+
+   memset(&ofn, 0, sizeof(ofn));
+   ofn.lStructSize = sizeof(ofn);
+   ofn.hwndOwner   = PDC_hWnd;
+   ofn.lpstrFile   = buf;
+   ofn.nMaxFile    = MAX_PATH;
+   ofn.lpstrTitle  = "Insert File";
+   ofn.Flags       = OFN_FILEMUSTEXIST | OFN_NOCHANGEDIR | OFN_PATHMUSTEXIST;
+
+   if (!GetOpenFileNameA(&ofn))
+       return FALSE;
+
+   normalize_slashes(buf);
+   answer = mallocstrcpy(answer, buf);
+   return TRUE;
+}
+#endif /* _WIN32 && SAVE_GUI */
+
 #include <errno.h>
 #include <fcntl.h>
 #include <libgen.h>
