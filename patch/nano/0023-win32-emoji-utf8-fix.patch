--- a/src/winio.c	2026-05-05 00:00:00.000000000 -0400
+++ b/src/winio.c	2026-05-05 00:00:00.000000000 -0400
@@ -1890,6 +1890,25 @@
 		if (mbtowide(&wc, text + index) < 0) {
 			wc = (wchar_t)0xFFFD; /* Replacement character for invalid sequences */
 			charlen = 1;
+#ifdef __WIN32
+			/* On Windows with 16-bit wchar_t, check if this is a 4-byte UTF-8 sequence
+			 * that mbtowide failed to convert. If so, pass the raw bytes through
+			 * instead of using the replacement character. */
+			if ((unsigned char)text[index] >= 0xF0 && 
+			    (unsigned char)text[index] <= 0xF4) {
+				/* This is a valid 4-byte UTF-8 start byte. Check if we have enough bytes. */
+				if (index + 3 < strlen(text)) {
+					/* Verify it's a valid 4-byte UTF-8 sequence */
+					if (((unsigned char)text[index + 1] >= 0x80 && (unsigned char)text[index + 1] <= 0xBF) &&
+					    ((unsigned char)text[index + 2] >= 0x80 && (unsigned char)text[index + 2] <= 0xBF) &&
+					    ((unsigned char)text[index + 3] >= 0x80 && (unsigned char)text[index + 3] <= 0xBF)) {
+						/* Valid 4-byte UTF-8 sequence - pass raw bytes through */
+						wc = (wchar_t)0xFFFE; /* Special marker for raw UTF-8 bytes */
+						charlen = 4;
+					}
+				}
+			}
+#endif
 		}
 
