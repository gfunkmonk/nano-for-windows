--- a/src/winio.c	2026-05-20 04:30:00.000000000 -0400
+++ b/src/winio.c	2026-05-20 04:30:00.000000000 -0400
@@ -1718,7 +1718,13 @@
 /* Move (in the given window) to the given row and wipe it clean. */
 void blank_row(WINDOW *window, int row)
 {
 	wmove(window, row, 0);
+#ifdef _WIN32
+	/* On Windows, explicitly write spaces to ensure emoji artifacts are cleared.
+	 * wclrtoeol() may not properly clear double-width emoji characters. */
+	mvwprintw(window, row, 0, "%*s", getmaxx(window), " ");
+#else
 	wclrtoeol(window);
+#endif
 }

