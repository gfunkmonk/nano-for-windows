+/* Toggle line numbers on the fly for the current buffer (M-6).
+ * Binds to 'togglelinenumbers' in .nanorc. */
+void do_toggle_linenumbers(void)
+{
+#ifdef ENABLE_LINENUMBERS
+	TOGGLE(LINE_NUMBERS);
+	/* Recompute the left-margin width so the edit area reflows. */
+	confirm_margin();
+	refresh_needed = TRUE;
+	statusline(REMARK, ISSET(LINE_NUMBERS) ? _("Line numbers enabled") :
+	                                         _("Line numbers disabled"));
+#else
+	statusline(AHEM, _("Line numbers support is not compiled in"));
+#endif
+}
 #endif /* !NANO_TINY */
 
