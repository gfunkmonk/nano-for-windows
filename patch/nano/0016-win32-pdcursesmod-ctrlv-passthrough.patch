--- a/src/nano.c
+++ b/src/nano.c
@@ -2211,6 +2211,17 @@ int main(int argc, char **argv)
 	 if (strcmp(argv[optind_], "-") == 0){scoop_stdin();break;}
 	if (initscr() == NULL)
 		exit(1);
+
+#ifdef __PDCURSESMOD__
+	/* Apply these after initscr(), because PDCursesMod initializes/reset
+	 * function-key defaults during startup. */
+	/* Disable the default Ctrl+V clipboard shortcut so Ctrl+V is handled as
+	 * nano's normal paste keystroke from the cutbuffer. */
+	PDC_set_function_key(FUNCTION_KEY_PASTE, 0);
+	/* Disable Ctrl+C abort mapping so Ctrl+C reaches nano as a keystroke and
+	 * can be used as dialog cancel. */
+	PDC_set_function_key(FUNCTION_KEY_ABORT, 0);
+#endif
 
 #ifdef ENABLE_COLOR
 	/* If the terminal can do colors, tell ncurses to switch them on. */
